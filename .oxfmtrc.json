{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 100,
    "tabWidth": 4,
    "singleQuote": false,
    "arrowParens": "always",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "htmlWhitespaceSensitivity": "css",
    "objectWrap": "preserve",
    "quoteProps": "consistent",
    "semi": true,
    "useTabs": false,
    "trailingComma": "es5",
    "sortTailwindcss": {
        "stylesheet": "./src/app.css"
    },
    "sortPackageJson": false,
    "ignorePatterns": [
        "package-lock.json",
        "pnpm-lock.yaml",
        "yarn.lock",
        "bun.lock",
        "bun.lockb",
        "/static/"
    ]
}
