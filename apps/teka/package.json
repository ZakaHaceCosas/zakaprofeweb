        "@tailwindcss/vite": "catalog:dev",
        "@types/bun": "catalog:dev",
        "@types/node": "catalog:dev",
        "eslint": "catalog:dev",
        "eslint-config-prettier": "catalog:dev",
        "eslint-plugin-svelte": "catalog:dev",
        "globals": "catalog:dev",
        "prettier": "catalog:dev",
        "prettier-plugin-svelte": "catalog:dev",
        "prettier-plugin-tailwindcss": "catalog:dev",
        "svelte": "catalog:dev",
        "svelte-check": "catalog:dev",
        "tailwindcss": "catalog:dev",
        "typescript": "catalog:dev",
        "typescript-eslint": "catalog:dev",
        "vercel": "catalog:dev",
